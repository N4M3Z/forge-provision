# forge-provision configuration — committed template.
# Copy to .env and edit values for this machine. .env is gitignored.
# Source: https://github.com/N4M3Z/forge-provision

# Your GitHub user/org. Used to construct clone URLs for own repos.
GITHUB_USER="your-github-user"

# Where reference repos and own siblings are cloned on this Mac.
DEV_DIR="${HOME}/Developer/${GITHUB_USER}"

# Old Mac mount path — only used by migration scripts when bringing state
# from a previous machine over a network volume. Leave empty otherwise.
OLD_MAC_MOUNT=""

# Convenience derivations — usually no need to override.
OLD_CLAUDE_DIR="${OLD_MAC_MOUNT}/.claude"
NEW_CLAUDE_DIR="${HOME}/.claude"

# Terminal theme — exact name of a .terminal file in
# ${TERMINAL_SCHEMES_REPO}/terminal/ (see scripts/install/terminal-theme.sh).
# Pick from mbadolato/iTerm2-Color-Schemes (450+ themes; e.g. Dracula, Tomorrow Night,
# Solarized Dark, Catppuccin Mocha, Nord, Tokyo Night) or your own themes repo.
TERMINAL_THEME="Dracula"

# Where .terminal files live. Default = mbadolato/iTerm2-Color-Schemes (canonical, auto-cloned).
# Override to your own ${DEV_DIR}/themes for personal themes.
TERMINAL_SCHEMES_REPO="${DEV_DIR}/iTerm2-Color-Schemes"
